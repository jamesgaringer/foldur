{
  "identifier": "default",
  "description": "Default capabilities for Foldur",
  "windows": ["*"],
  "permissions": [
    "core:default",
    "sql:default",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-close",
    "dialog:default",
    "dialog:allow-open",
    "fs:default",
    "fs:allow-read-file"
  ]
}

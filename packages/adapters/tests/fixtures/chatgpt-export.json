            "content_type": "text",
            "parts": ["How do I build a CLI tool in Rust?"]
          }
        },
        "parent": "root",
        "children": ["msg-2"]
      },
      "msg-2": {
        "id": "msg-2",
        "message": {
          "id": "msg-2",
          "author": { "role": "assistant" },
          "create_time": 1700000200,
          "content": {
            "content_type": "text",
            "parts": ["Here's how to build a CLI tool in Rust:\n\n```rust\nuse clap::Parser;\n\n#[derive(Parser)]\nstruct Args {\n    name: String,\n}\n\nfn main() {\n    let args = Args::parse();\n    println!(\"Hello, {}!\", args.name);\n}\n```\n\nYou'll want to add `clap` to your Cargo.toml."]
          }
        },
        "parent": "msg-1",
        "children": ["msg-3"]
      },
      "msg-3": {
        "id": "msg-3",
        "message": {
          "id": "msg-3",
          "author": { "role": "user" },
          "create_time": 1700000300,
          "content": {
            "content_type": "text",
            "parts": ["Can you add error handling?"]
          }
        },
        "parent": "msg-2",
        "children": ["msg-4"]
      },
      "msg-4": {
        "id": "msg-4",
        "message": {
          "id": "msg-4",
          "author": { "role": "assistant" },
          "create_time": 1700000400,
          "content": {
            "content_type": "text",
            "parts": ["Sure! Here's an updated version with error handling:\n\n```rust\nuse anyhow::Result;\nuse clap::Parser;\n\nfn main() -> Result<()> {\n    let args = Args::parse();\n    Ok(())\n}\n```"]
          }
        },
        "parent": "msg-3",
        "children": []
      }
    }
